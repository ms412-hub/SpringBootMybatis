<?xml version="1.0" encoding="UTF-8"?>

<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <property name="log_dir" value="/data/lof/SpringBootMyBatis"/>

    <appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log_dir}/applog.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} [%-5level] %logger{36} - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>

        <rolingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${log.dir}/applog.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rolingPolicy>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <Logger name="kopo.poly" level="INFO" addtiivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="File"/>
    </Logger>
</configuration>